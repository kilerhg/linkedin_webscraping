LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# --- Daily digest tuning (quality over quantity, <=5/day) ---
JOB_SUMMARY_TOP_N=5
JOB_SUMMARY_MIN_SCORE=18
JOB_EXCLUDE_DEALBREAKERS=True
JOB_REQUIRE_REMOTE=False

# --- Real-time alert poller (7-9am) ---
